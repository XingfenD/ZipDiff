set -eu

# $1 -- the path of zip file
# $2 -- the path of output (/output/xx-parser_name/xxx.zip/)

filename=$(basename "$1")
src_dir="/workspace/src"

# Info-ZIP `make -f ./unix/Makefile generic` produces `/workspace/src/unzip`.
# Keep a couple of fallbacks for compatibility with other build layouts.
executable=""
for candidate in \
    "$src_dir/unzip" \
    "$src_dir/build-coverage/bins/unzip" \
    "$src_dir/build-coverage/bins/unzzip"
do
    if [ -x "$candidate" ]; then
        executable="$candidate"
        break
    fi
done

if [ -z "$executable" ]; then
    echo "[ERROR] unzip executable not found under $src_dir" >&2
    exit 1
fi

find "$src_dir" -name "*.gcda" -delete
cd "$2"
"$executable" "$1"

/workspace/coverage.sh "$src_dir" "$filename" "$2/.."
