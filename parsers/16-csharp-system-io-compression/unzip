#!/bin/sh

set -eu

filename=$(basename "$1")
cov_dir=$(mktemp -d 2>/dev/null || mktemp -d -t cov)
cov_prefix="$cov_dir/coverage"

trap 'rm -rf "$cov_dir"' EXIT

/tools/dotnet-coverage collect \
    dotnet /build/unzip.dll "$1" "$2" \
    -f cobertura \
    -o "$cov_prefix.cobertura.xml" >/dev/null 2>&1 || {
    dotnet /build/unzip.dll "$1" "$2"
    printf "0\n" > "$2/../$filename.covinfo"
    exit 0
}

/workspace/coverage.sh "$cov_prefix.cobertura.xml" "System.IO.Compression" "$filename" "$2/.." || printf "0\n" > "$2/../$filename.covinfo"
