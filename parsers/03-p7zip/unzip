#!/bin/sh

set -eu

filename=$(basename "$1")
src_dir="/workspace/src"

executable=""
for candidate in \
    "/workspace/src/bin/7za" \
    "/workspace/src/bin/7z" \
    "/usr/bin/7z" \
    "/usr/bin/7za"
do
    if [ -x "$candidate" ]; then
        executable="$candidate"
        break
    fi
done

if [ -z "$executable" ]; then
    echo "[ERROR] p7zip executable not found under $src_dir" >&2
    exit 1
fi

find "$src_dir" -name "*.gcda" -delete
"$executable" t "$1"
"$executable" x -aoa "$1" -o"$2"

/workspace/coverage.sh "$src_dir" "$filename" "$2/.."
